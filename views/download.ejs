<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Download | InShare - File Sharing Made Easy</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .download-btn {
            display: block;
            margin: 20px auto;
            width: fit-content;
        }
    </style>
</head>
<body>
    <img src="/img/logo.png" alt="Inshare logo" class="logo">
    <div class="download-container">
        <div class="icon-container" style="margin: 0 auto 20px;">
            <img src="/img/download.png" class="center" alt="download icon">
        </div>
        <% if(locals.error){ %>
            <h4><%= locals.error %> 😔</h4>
        <% } else { %>
            <h2>Your file is ready to download</h2>
            <p>Link expires in 24 hours</p>
            <div class="download__meta">
                <h4><%= fileName %></h4>
                <small><%= size %></small>
            </div>
            <a href="<%= downloadLink %>" class="download-btn">Download file</a>
        <% } %>
    </div>
</body>
</html>